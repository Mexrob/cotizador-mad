generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// User Management
enum UserRole {
  ADMIN
  DEALER
  RETAIL
  VIP
  WHOLESALE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole   @default(RETAIL)
  status        UserStatus @default(PENDING)
  
  // Business Information
  companyName   String?
  taxId         String?    // RFC for Mexico
  fiscalRegime  String?    // Régimen Fiscal
  cfdiUse       String?    // Uso de CFDI
  phone         String?
  phone2        String?    // Teléfono 2 (opcional)
  
  deliveryAddress   DeliveryAddress? @relation(fields: [deliveryAddressId], references: [id])
  deliveryAddressId String? @unique
  
  billingAddress    BillingAddress? @relation(fields: [billingAddressId], references: [id])
  billingAddressId  String? @unique
  
  country       String     @default("Mexico")
  
  // Pricing Information
  discountRate  Float      @default(0)
  creditLimit   Float      @default(0)
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  accounts      Account[]
  sessions      Session[]
  quotes        Quote[]
  quotesShared  QuoteShare[]
  notifications Notification[]
  wizardAssignments WizardAssignment[]
  wizardUsages    WizardUsage[]
  
  @@map("users")
}

model DeliveryAddress {
  id             String  @id @default(cuid())
  street         String
  exteriorNumber String
  interiorNumber String?
  colony         String
  zipCode        String
  city           String
  state          String
  
  user           User?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@map("delivery_addresses")
}

model BillingAddress {
  id             String  @id @default(cuid())
  street         String
  number         String
  colony         String
  zipCode        String
  city           String
  state          String
  
  user           User?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@map("billing_addresses")
}

// Company Configuration
model CompanySettings {
  id            String   @id @default(cuid())
  companyName   String
  logo          String?
  address       String
  city          String
  state         String
  zipCode       String
  country       String   @default("Mexico")
  phone         String
  email         String
  website       String?
  taxId         String   // RFC
  
  // Branding
  primaryColor  String   @default("#1f2937")
  secondaryColor String  @default("#3b82f6")
  tertiaryColor String   @default("#10b981")
  
  // Business Settings
  currency      String   @default("MXN")
  timezone      String   @default("America/Mexico_City")
  language      String   @default("es")
  sessionTimeoutMinutes Int @default(15) // Session timeout in minutes
  
  // Special Options Percentages
  expressDeliveryPercentage Float @default(20) // Percentage for express delivery
  exhibitionPercentage Float @default(25) // Percentage for exhibition/demo products
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("company_settings")
}

model TaxSettings {
  id          String  @id @default(cuid())
  name        String
  rate        Float
  isDefault   Boolean @default(false)
  description String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("tax_settings")
}

// Product Catalog
enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

model Category {
  id          String        @id @default(cuid())
  name        String
  description String?
  image       String?
  parentId    String?
  status      ProductStatus @default(ACTIVE)
  
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("categories")
}

model Material {
  id          String        @id @default(cuid())
  name        String
  description String?
  image       String?
  color       String?
  finish      String?
  texture     String?
  status      ProductStatus @default(ACTIVE)
  
  // Pricing
  costPerUnit Float
  unit        String        @default("m2")
  
  
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("materials")
}

model Hardware {
  id          String        @id @default(cuid())
  name        String
  description String?
  image       String?
  type        String        // handle, hinge, drawer_slide, etc.
  brand       String?
  model       String?
  status      ProductStatus @default(ACTIVE)
  
  // Pricing
  costPerUnit Float
  unit        String        @default("piece")
  
  
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("hardware")
}

model Brand {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  imageUrl    String?
  website     String?
  status      ProductStatus @default(ACTIVE)
  sortOrder   Int          @default(0)

  

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("brands")
}

model Product {
  // Obligatorios
  id          String   @id @default(cuid())
  name        String   @default("Producto")
  categoryId  String   @default("default")
  status      ProductStatus @default(ACTIVE)
  
  // Campos principales
  categoria       String?   // Categoria (Puerta/Ventana)
  coleccion       String?   // Colección
  linea           String?   // Línea de producto
  tonoColor       String?   // Tono o Color
  tonoVidrio     String?   // Tono de Vidrio
  tonoAluminio   String?   // Tono de Aluminio
  precioBaseM2   Float?    // Precio Base por metro cuadrado
  tiempoEntrega  Int?      // Tiempo de entrega (días hábiles)
  
  // Dimensiones PUERTA
  puertaAnchoMin Float?    // PUERTA Ancho Mínimo (mm)
  puertaAnchoMax Float?    // PUERTA Ancho Máximo (mm)
  puertaAltoMin  Float?    // PUERTA Alto Mínimo (mm)
  puertaAltoMax  Float?    // PUERTA Alto Máximo (mm)
  
  // Dimensiones FRENTE
  frenteAnchoMin Float?    // FRENTE Ancho Mínimo (mm)
  frenteAnchoMax Float?    // FRENTE Ancho Máximo (mm)
  frenteAltoMin  Float?    // FRENTE Alto Mínimo (mm)
  frenteAltoMax  Float?    // FRENTE Alto Máximo (mm)
  
  // Dimensiones VENTANA
  ventanaAnchoMin Float?   // VENTANA Ancho Mínimo (mm)
  ventanaAnchoMax Float?   // VENTANA Ancho Máximo (mm)
  ventanaAltoMin  Float?   // VENTANA Alto Mínimo (mm)
  ventanaAltoMax  Float?   // VENTANA Alto Máximo (mm)
  
  // Precio vidrio
  precioVidrio   Float?    // PRECIO DE VIDRIO CLARO DE 4MM
  
  // Imágenes
  images         String[]  // Array de URLs de imágenes
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relaciones
  pricing     ProductPricing[]
  quoteItems  QuoteItem[]
  
  @@map("products")
}

model DoorType {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  status      ProductStatus @default(ACTIVE)
  
  quoteItems  QuoteItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("door_types")
}

model DoorModel {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  status      ProductStatus @default(ACTIVE)
  
  quoteItems  QuoteItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("door_models")
}

model ColorTone {
  id          String        @id @default(cuid())
  name        String        @unique
  hexCode     String?
  imageUrl    String?
  status      ProductStatus @default(ACTIVE)
  
  quoteItems  QuoteItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("color_tones")
}

model WoodGrain {
  id          String        @id @default(cuid())
  name        String        @unique
  direction   String?       // Vertical, Horizontal
  imageUrl    String?
  status      ProductStatus @default(ACTIVE)
  
  quoteItems  QuoteItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("wood_grains")
}

model Handle {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  imageUrl    String?
  cost        Float         @default(0)
  status      ProductStatus @default(ACTIVE)
  quoteItems  QuoteItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("handles")
}

// Pricing System
model ProductPricing {
  id          String   @id @default(cuid())
  productId   String?
  userRole    UserRole
  basePrice   Float
  markup      Float    @default(0)
  finalPrice  Float
  
  product     Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([productId, userRole])
  @@map("product_pricing")
}

// Quotation System
enum QuoteStatus {
  DRAFT
  PENDING // Mantener los estados antiguos
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
  SENT_TO_CLIENT // Enviada al cliente
  APPROVED_BY_CLIENT // Aprobada por cliente
  PAID // Pagado
  IN_PRODUCTION // En Producción
  READY_FOR_DELIVERY // Listo para Entrega
  INVOICED // Facturado
  COMPLETED // Completado
  CANCELLED // Cancelado
}

model Quote {
  id              String        @id @default(cuid())
  quoteNumber     String        @unique
  userId          String
  status          QuoteStatus   @default(PENDING)
  
  // Customer Information
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerAddress String?
  
  // Project Information
  projectName     String
  projectAddress  String?
  roomDimensions  Json?         // {width: 4.5, height: 2.4, depth: 3.2}
  
  @@index([userId])
  @@index([status])
  @@index([customerEmail])
  
  // Pricing
  subtotal        Float         @default(0)
  taxAmount       Float         @default(0)
  discountAmount  Float         @default(0)
  totalAmount     Float         @default(0)
  
  // New pricing options
  isExpressOrder  Boolean       @default(false)
  isExhibitionOrder Boolean     @default(false)
  
  // Dates
  validUntil      DateTime
  deliveryDate    DateTime?
  validationDate  DateTime?     // Fecha de Validación (Pago)
  productionEndDate DateTime?   // Fecha de Salida de Producción
  
  // Notes and Files
  notes           String?
  attachments     String[]      // URLs to files
  paymentProof    String?       // URL to payment proof (image or PDF)
  invoicePdf      String?       // URL to official invoice PDF
  invoiceXml      String?       // URL to official invoice XML
  
  // Design Configuration
  design3d        Json?         // 3D configuration data
  floorPlan       String?       // URL to floor plan image
  
  user            User          @relation(fields: [userId], references: [id])
  items           QuoteItem[]
  shares          QuoteShare[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@map("quotes")
}

model QuoteItem {
  id            String  @id @default(cuid())
  quoteId       String
  productId     String?
  quantity      Int     @default(1)
  
  // Customization
  customWidth   Float?
  customHeight  Float?
  customDepth   Float?
  
  // New fields for door configuration per item
  doorTypeId      String?
  doorModelId     String?
  colorToneId     String?
  woodGrainId     String?
  handleId        String?
  isTwoSided      Boolean?      @default(false)
  isExhibition    Boolean       @default(false)
  isExpressDelivery Boolean     @default(false)
  edgeBanding     String?       // "Similar al tono del vidrio" | "Tono Aluminio"
  
  // Relationships for item configuration
  doorType        DoorType?    @relation(fields: [doorTypeId], references: [id])
  doorModel       DoorModel?   @relation(fields: [doorModelId], references: [id])
  colorTone       ColorTone?   @relation(fields: [colorToneId], references: [id])
  woodGrain       WoodGrain?   @relation(fields: [woodGrainId], references: [id])
  handle          Handle?      @relation(fields: [handleId], references: [id])
  
  @@index([quoteId])
  @@index([productId])
  
  // New relation to product line for configured items
  productLineId   String?
  productLine     ProductLine? @relation(fields: [productLineId], references: [id])
  productToneId   String?
  productTone     ProductTone? @relation(fields: [productToneId], references: [id])
  handleModelId   String?
  handleModel     HandleModel? @relation(fields: [handleModelId], references: [id])
  ceramicColor    String?      // Color selection for ceramic products (e.g., "DANAE", "KELYA")
  vetaOrientation String?      // Orientation for ceramic products (e.g., "vertical", "horizontal")
  jaladera          String?      // Jaladera name for ceramic products (e.g., "JAL-001")
  jaladeraOrientation String?   // Orientation for jaladera (e.g., "vertical", "horizontal")
  cubrecanto        String?     // Cubrecanto selection (e.g., "Tono Aluminio", "Similar al tono")
  handlePrice      Float?       // Price of the handle/jaladera separately
  
  // Pricing
  unitPrice     Float
  totalPrice    Float
  pricePerSquareMeter Float?    // Precio base por m² del tono seleccionado
  packagingCost Float         @default(0) // Costo de Empaque calculado por Alto × Ancho
  expressAmount Float         @default(0) // Monto de envío express calculado
  exhibitionAmount Float      @default(0) // Monto de descuento de exhibición calculado
  
  quote         Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product       Product? @relation(fields: [productId], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("quote_items")
}

model QuoteShare {
  id        String   @id @default(cuid())
  quoteId   String
  userId    String
  shareType String   @default("view") // view, edit, admin
  
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
  
  @@unique([quoteId, userId])
  @@map("quote_shares")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  message     String
  type        String   // 'info', 'success', 'warning', 'error', 'payment_proof'
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("notifications")
}



// System Logs for Compliance
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // CREATE, UPDATE, DELETE, VIEW
  table     String   // Table affected
  recordId  String   // ID of affected record
  oldData   Json?    // Previous state
  newData   Json?    // New state
  ipAddress String?
  userAgent String?
  
  createdAt DateTime @default(now())
  
  @@map("audit_logs")
}

// Product Configuration System
// These models support the guided assistant for product configuration

model ProductLine {
  id          String        @id @default(cuid())
  name        String        @unique // "VIDRIO", "LÍNEA CERÁMICA", "LÍNEA ALHÚ", etc.
  description String?
  code        String?       @unique // Short code for SKU generation
  imageUrl    String?       // Main image for the line
  isActive    Boolean       @default(true)
  sortOrder   Int           @default(0) // Display order in UI
  
  // Relationships
  
  tones       ProductTone[]
  quoteItems  QuoteItem[]  // Back-reference to quote items using this line
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@map("product_lines")
}

model ProductTone {
  id          String       @id @default(cuid())
  name        String       // "BLANCO", "DEKTON", "NATURAL", etc.
  lineId      String
  line        ProductLine  @relation(fields: [lineId], references: [id], onDelete: Cascade)
  
  description String?
  imageUrl    String?      // Image showing the tone/color
  hexColor    String?      // Hex color code for preview (if applicable)
  
  // Configuration options
  supportsTwoCars     Boolean  @default(false) // Si soporta 2 caras
  supportsHorizontalGrain Boolean @default(false) // Si soporta veta horizontal (FOIL)
  supportsVerticalGrain   Boolean @default(false) // Si soporta veta vertical (FOIL)
  
  // Pricing adjustments (optional, can be 0 if no adjustment)
  priceAdjustment     Decimal  @default(0) @db.Decimal(10, 2) // Ajuste al precio base
  twoCarsAdjustment   Decimal  @default(0) @db.Decimal(10, 2) // Costo adicional por 2 caras
  
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  
  quoteItems  QuoteItem[] // Back-reference to quote items using this tone
  
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([lineId, name])
  @@map("product_tones")
}

model EdgeBanding {
  id          String   @id @default(cuid())
  name        String   @unique // "PVC BLANCO", "MELAMINA NOGAL", etc.
  description String?
  imageUrl    String?
  
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  
  
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("edge_bandings")
}

model HandleModel {
  id          String   @id @default(cuid())
  name        String   @unique // "JALADERA MODELO SORENTO A NEGRO"
  model       String?  // "SORENTO A", "SORENTO L", "SORENTO G"
  finish      String?  // "NEGRO", "ALUMINIO"
  
  description String?
  imageUrl    String?
  
  // Pricing
  price       Decimal  @db.Decimal(10, 2) // Precio de la jaladera
  priceUnit   String   @default("unit") // "unit" o "ml" (metro lineal)
  
  // Specifications
  length      Int?     // Longitud en mm (si aplica)
  width       Int?     // Ancho en mm (si aplica)
  
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  
  
  quoteItems  QuoteItem[] // Back-reference to quote items using this handle
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("handle_models")
}

model ProductBackFace {
  id              String   @id @default(cuid())
  name            String   @unique // "Blanca", "Especialidad", "Dos Caras"
  description     String?
  priceAdjustment Decimal  @default(0) @db.Decimal(10, 2)
  isTwoSided      Boolean  @default(false) // Flag for special "Dos Caras" logic
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("product_back_faces")
}

// Configurable Wizard System
// This system allows admins to create custom wizards with different steps,
// calculations, and assign them to specific users/roles

model WizardTemplate {
  id          String   @id @default(cuid())
  name        String   // "Wizard Estándar Puertas", "Wizard Express", etc.
  description String?
  code        String   @unique // "standard-doors", "express-kit", etc.
  
  // Status
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false) // Default wizard for new users
  
  // Steps configuration (JSON para flexibilidad)
  stepsConfig Json     // Array de pasos con su configuración
  
  // Pricing configuration
  pricingConfig Json?  // Fórmulas y reglas de cálculo de precios
  
  // Validation rules
  validationRules Json? // Reglas de validación por paso
  
  // UI Configuration
  uiConfig    Json?    // Colores, estilos, textos personalizados
  
  // Relationships
  assignments WizardAssignment[]
  usages      WizardUsage[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("wizard_templates")
}

model WizardStepDefinition {
  id          String   @id @default(cuid())
  name        String   // "Selección de Categoría", "Dimensiones", etc.
  code        String   @unique // "category-selection", "dimensions", etc.
  
  // Component info
  componentName String // Nombre del componente React a renderizar
  componentPath String // Ruta al componente (opcional, para pasos dinámicos)
  
  // Step metadata
  description String?
  icon        String?  // Nombre del icono Lucide
  isSystem    Boolean  @default(false) // Pasos del sistema vs custom
  
  // Configuration schema (para validar el config del paso)
  configSchema Json?   // JSON Schema para validar la configuración
  
  // Default configuration
  defaultConfig Json?
  
  // Step type
  stepType    WizardStepType @default(STANDARD)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("wizard_step_definitions")
}

enum WizardStepType {
  STANDARD      // Paso estándar del sistema
  CUSTOM        // Paso personalizado creado por admin
  CONDITIONAL   // Paso que aparece según condiciones
  CALCULATION   // Paso de cálculo automático
}

model WizardAssignment {
  id        String   @id @default(cuid())
  
  // Assignment scope
  templateId String
  userId    String?  // Asignación a usuario específico
  role      UserRole? // Asignación a rol
  
  // Priority (si hay conflictos)
  priority  Int      @default(0)
  
  // Date range (opcional)
  validFrom DateTime?
  validUntil DateTime?
  
  // Relationships
  template  WizardTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user      User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([templateId, userId])
  @@unique([templateId, role])
  @@map("wizard_assignments")
}

model WizardUsage {
  id        String   @id @default(cuid())
  
  templateId String
  userId    String
  quoteId   String?
  
  // Usage data
  startedAt DateTime @default(now())
  completedAt DateTime?
  stepData  Json?    // Datos recolectados en cada paso
  
  @@index([userId])
  @@index([templateId])
  @@index([quoteId])
  
  // Performance metrics
  durationSeconds Int? // Tiempo total en segundos
  
  // Relationships
  template  WizardTemplate @relation(fields: [templateId], references: [id])
  user      User           @relation(fields: [userId], references: [id])
  
  createdAt DateTime @default(now())
  
  @@map("wizard_usages")
}

model PricingFormula {
  id          String   @id @default(cuid())
  name        String   // "Cálculo Vidrio", "Cálculo Alhú", etc.
  code        String   @unique // "glass-calculation", "alhu-calculation"
  
  // Formula definition
  formula     String   // Expresión matemática o JavaScript
  variables   Json     // Variables disponibles: { "width": "number", "height": "number" }
  
  // Conditions
  conditions  Json?    // Condiciones para aplicar esta fórmula
  
  // Metadata
  description String?
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("pricing_formulas")
}

model ExtraService {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("extra_services")
}

model ShippingCost {
  id          String   @id @default(cuid())
  zone        String
  description String?
  cost        Float
  freeFrom    Float?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("shipping_costs")
}
