# Database Configuration
# Reemplaza con tus credenciales reales de PostgreSQL
DATABASE_URL="postgresql://usuario:password@localhost:5432/cotizador_mad?schema=public"

# NextAuth Configuration
# URL de tu aplicación (debe coincidir con tu dominio)
NEXTAUTH_URL="http://tu-dominio.com"

# Genera un secret aleatorio con: openssl rand -base64 32
NEXTAUTH_SECRET="genera-un-secret-aleatorio-muy-largo-aqui"

# Application Configuration
NODE_ENV="production"
PORT=3000

# Optional: Email Configuration (si planeas usar notificaciones por email)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="tu-email@gmail.com"
# SMTP_PASSWORD="tu-password-de-aplicacion"
# SMTP_FROM="noreply@tu-dominio.com"

# Optional: Storage Configuration (si usas almacenamiento en la nube)
# AWS_ACCESS_KEY_ID="tu-access-key"
# AWS_SECRET_ACCESS_KEY="tu-secret-key"
# AWS_REGION="us-east-1"
# AWS_BUCKET_NAME="tu-bucket"

# Optional: Analytics
# GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
